{
  "name": "@ramiidv/arca-empleados",
  "version": "0.1.0",
  "description": "TypeScript SDK para gestion de empleados con ARCA (ex AFIP) - Generacion de archivos F935 para altas, bajas y modificaciones",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "llms.txt",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "arca",
    "afip",
    "empleados",
    "f935",
    "argentina",
    "sdk",
    "typescript",
    "simplificacion-registral",
    "alta",
    "baja"
  ],
  "author": "ramiidv",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ramiidv/arca-empleados-sdk.git"
  },
  "homepage": "https://github.com/ramiidv/arca-empleados-sdk#readme",
  "bugs": {
    "url": "https://github.com/ramiidv/arca-empleados-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@ramiidv/arca-common": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
